{
  "api": {
    "host": "0.0.0.0",
    "port": 8000
  },
  "features": {
    "categorical_onehot": [
      "key",
      "mode"
    ],
    "n_bins": 5,
    "numeric_passthrough": [
      "acousticness",
      "danceability",
      "energy",
      "instrumentalness",
      "liveness",
      "loudness",
      "speechiness",
      "valence"
    ],
    "quantile_bin": [
      "duration_ms",
      "tempo"
    ]
  },
  "inference": {
    "source": "wandb"
  },
  "logging": {
    "format": "text",
    "level": "INFO"
  },
  "paths": {
    "artifact_cache_dir": ".artifacts",
    "clean_data": "data/processed/clean.csv",
    "log_file": "logs/pipeline.log",
    "metrics_path": "reports/metrics.json",
    "model_path": "models/model.joblib",
    "raw_data": "data/raw/SpotifyAudioFeaturesApril2019.csv",
    "report_path": "reports/predictions.csv",
    "run_config_path": "reports/run_config.json"
  },
  "project": {
    "name": "Spotify Sound Archetypes",
    "problem_type": "regression",
    "target_column": "popularity"
  },
  "train": {
    "baseline_model": "rf",
    "rf_max_depth": 10,
    "rf_n_estimators": 100,
    "seed": 42,
    "test_size": 0.2,
    "val_size": 0.2
  },
  "wandb": {
    "enabled": true,
    "entity": "nicopbeard-ie-university",
    "log_predictions": true,
    "log_processed_data": true,
    "model_artifact_name": "spotify-popularity-pipeline",
    "production_alias": "prod",
    "project": "spotify-sound-archetypes",
    "run_name": "final-rf-candidate",
    "tags": [
      "final-assignment",
      "model-selection",
      "rf"
    ]
  }
}