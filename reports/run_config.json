{
  "features": {
    "categorical_onehot": [
      "key",
      "mode"
    ],
    "n_bins": 5,
    "numeric_passthrough": [
      "acousticness",
      "danceability",
      "energy",
      "instrumentalness",
      "liveness",
      "loudness",
      "speechiness",
      "valence"
    ],
    "quantile_bin": [
      "duration_ms",
      "tempo"
    ]
  },
  "paths": {
    "clean_data": "data/processed/clean.csv",
    "model_path": "models/model.joblib",
